-- Preview

SELECT 
    IncidentId,
    IncidentTitle AS CurrentTitle,
    IncidentCreatedDate,
    CONCAT(
        'INC-',
        FORMAT(IncidentCreatedDate, 'yyyyMMdd'),
        '-',
        RIGHT('0000' + CAST(IncidentId AS VARCHAR(4)), 4)
    ) AS NewTitlePreview
FROM Incidents
ORDER BY IncidentId;



-- Update


UPDATE Incidents
SET IncidentTitle = CONCAT(
    'INC-',
    FORMAT(IncidentCreatedDate, 'yyyyMMdd'),
    '-',
    RIGHT('0000' + CAST(IncidentId AS VARCHAR(4)), 4)
);
